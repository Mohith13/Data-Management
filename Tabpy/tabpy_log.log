     model.fit(data)
 
     # Getting the Predicted Outliers
     df['anomaly'] = pd.Series(model.predict(data))
 
     # Setting the 'anomaly' column as boolean
     df['anomaly'] = [True if x == -1 else False for x in df['anomaly']]
 
     output_df = input_df
     
